{
  "name": "devnotes-plus",
  "displayName": "DevNotes+",
  "description": "Project-scoped developer notes anchored to files & git branches. Features rich block editor (images, tables, code), Claude Code integration, team sharing, and more.",
  "version": "0.1.1",
  "icon": "media/icon.png",
  "publisher": "HibaChaabnia",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hiba-Chaabnia/DevNotes-Plus"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devnotes-plus-container",
          "title": "DevNotes",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "devnotes-plus-container": [
        {
          "type": "webview",
          "id": "devnotesPlusNoFolderView",
          "name": "DevNotes",
          "when": "workspaceFolderCount == 0"
        },
        {
          "type": "webview",
          "id": "devnotesPlusView",
          "name": "Notes",
          "visibility": "collapsed",
          "when": "workspaceFolderCount != 0"
        },
        {
          "type": "webview",
          "id": "devnotesPlusActivityView",
          "name": "Activity",
          "visibility": "collapsed",
          "when": "workspaceFolderCount != 0 && devnotesPlus.hasActivity"
        }
      ]
    },
    "commands": [
      {
        "command": "devnotesPlus.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.jumpToLink",
        "title": "Jump to Linked File",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.quickCapture",
        "title": "Add DevNote Here",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.exportAll",
        "title": "Export All Notes",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.exportNote",
        "title": "Export Note",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.refreshActivity",
        "title": "Refresh Activity Feed",
        "icon": "$(refresh)",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.registerMcp",
        "title": "Connect to Claude Code (Register MCP Server)",
        "category": "DevNotes"
      },
      {
        "command": "devnotesPlus.focusSidebar",
        "title": "Open DevNotes Sidebar",
        "category": "DevNotes"
      }
    ],
    "keybindings": [
      {
        "command": "devnotesPlus.quickCapture",
        "key": "ctrl+alt+q",
        "mac": "cmd+alt+q"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devnotesPlus.refresh",
          "when": "view == devnotesPlusView",
          "group": "navigation@1"
        },
        {
          "command": "devnotesPlus.refreshActivity",
          "when": "view == devnotesPlusActivityView",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "devnotesPlus.quickCapture",
          "when": "editorTextFocus",
          "group": "devnotesPlus@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run bundle:extension && npm run build:webview && npm run bundle:mcp",
    "bundle:extension": "esbuild src/extension.ts --bundle --outfile=out/extension.js --platform=node --external:vscode --minify",
    "bundle:mcp": "esbuild mcp-server/src/index.ts --bundle --outfile=mcp-server/dist/index.js --platform=node --format=cjs --minify --tsconfig=mcp-server/tsconfig.json",
    "build:webview": "npm run build:editor && npm run build:sidebar-editor",
    "build:editor": "esbuild src/webview/editor.ts --bundle --outfile=media/editor.js --platform=browser --target=es2020 --minify",
    "build:sidebar-editor": "esbuild src/webview/sidebar-editor.ts --bundle --outfile=media/sidebar-editor.js --platform=browser --target=es2020 --minify",
    "package": "vsce package",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "lucide": "^1.12.0",
    "tiptap-markdown": "^0.9.0"
  }
}
